# Derived image: iic-osic-tools + chipify (HTTPS server pre-installed).
#
# This image lets users `docker run` it and have the Chipify GUI offload
# sweeps to it over HTTPS. The container speaks HTTPS itself; the host
# needs no extra configuration beyond a `docker run -p` port mapping.
#
# Build (from the repo root):
#   docker build \
#       -f tools/server/Dockerfile.iic-osic-tools+chipify \
#       -t chipify-ee:latest .
#
# Run:
#   docker run -d --name chipify-ee \
#       -p 8443:8443 \
#       -v $HOME/designs:/foss/designs \
#       chipify-ee:latest
#
# First start auto-generates a self-signed TLS cert at
# /home/headless/.chipify/server-{cert,key}.pem and a bearer token at
# /home/headless/.chipify/server-token. Read both with:
#   docker exec chipify-ee cat /home/headless/.chipify/server-token
#   docker exec chipify-ee openssl x509 \
#       -in /home/headless/.chipify/server-cert.pem \
#       -noout -fingerprint -sha256
# and paste them into the Chipify GUI's Remote tab.
#
ARG BASE=hpretl/iic-osic-tools:latest
FROM ${BASE}

ARG REMOTE_USER=headless
USER ${REMOTE_USER}
WORKDIR /home/${REMOTE_USER}

# Install chipify with both client and server extras. The server extra
# pulls in fastapi / uvicorn / python-multipart / cryptography.
COPY --chown=${REMOTE_USER}:${REMOTE_USER} . /tmp/chipify-src
RUN python3 -m pip install --user --no-warn-script-location \
        "/tmp/chipify-src[remote,server]" \
 && rm -rf /tmp/chipify-src \
 && mkdir -p /home/${REMOTE_USER}/.chipify

# Default chipify env (override by mounting a file at the same path).
RUN printf '%s\n' \
        'export PDK_ROOT="/foss/pdks"' \
        'export PDK="ihp-sg13g2"' \
    > /home/${REMOTE_USER}/.chipify-env \
 && chmod 0600 /home/${REMOTE_USER}/.chipify-env

ENV CHIPIFY_WORK_DIR=/tmp/chipify_remote
EXPOSE 8443

# Source the env file so PDK_ROOT/PDK are visible to chipify-cli's
# subprocesses, then exec the server. uvicorn logs to stdout which
# `docker logs` captures.
CMD ["/bin/bash", "-lc", \
     ". /home/headless/.chipify-env && \
      exec /home/headless/.local/bin/chipify-cli serve \
          --host 0.0.0.0 --port 8443 \
          --work-dir ${CHIPIFY_WORK_DIR}"]
